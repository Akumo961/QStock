# ============================================================================
# QR Inventory System - Environment Configuration
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Full database URL (PostgreSQL)
# Format: postgresql://ali.el-sayed-ali@scouthorizon.onmicrosoft.com:Kaido1234@host:port/database_name
DATABASE_URL=postgresql://postgres@localhost:3016/qr_inventory

# Individual database parameters (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=3016
DB_NAME=qr_inventory
DB_USER=qr_admin
DB_PASSWORD=Kaido1234

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600


# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application name and version
APP_NAME=QR Inventory System
APP_VERSION=1.0.0

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (True for development, False for production)
DEBUG=True

# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Number of worker processes (for production)
WORKERS=4

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO


# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# SECRET KEY for JWT tokens and encryption
# IMPORTANT: Generate a secure random key for production!
# You can generate one using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32

# JWT Algorithm
ALGORITHM=HS256

# Access token expiration time (in minutes)
# Default: 1440 minutes = 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Refresh token expiration (in days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing algorithm (bcrypt)
PASSWORD_HASH_ROUNDS=12

# Session timeout (minutes)
SESSION_TIMEOUT=30


# ============================================================================
# CORS (Cross-Origin Resource Sharing) SETTINGS
# ============================================================================

# Allowed origins for CORS (comma-separated)
# For development with React on port 3000 and Vite on port 5173
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# For production, use your actual domain(s)
# BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=True

# Allowed HTTP methods
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS","PATCH"]

# Allowed headers
CORS_ALLOW_HEADERS=["*"]


# ============================================================================
# QR CODE CONFIGURATION
# ============================================================================

# QR Code generation settings
QR_CODE_VERSION=1
QR_CODE_SIZE=10
QR_CODE_BORDER=4
QR_CODE_BOX_SIZE=10

# QR Code error correction level (L, M, Q, H)
# L = 7%, M = 15%, Q = 25%, H = 30% error correction
QR_CODE_ERROR_CORRECTION=H

# QR Code colors
QR_CODE_FILL_COLOR=black
QR_CODE_BACK_COLOR=white


# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Upload directory path
UPLOAD_DIR=./uploads

# Maximum file upload size (in bytes)
# 5MB = 5242880 bytes
# 10MB = 10485760 bytes
MAX_UPLOAD_SIZE=5242880

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xls,.xlsx

# Image optimization settings
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=85


# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================

# Enable email notifications
EMAIL_ENABLED=False

# SMTP server settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# Email credentials
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Email sender information
MAIL_FROM=noreply@qr-inventory.com
MAIL_FROM_NAME=QR Inventory System

# Admin email for notifications
ADMIN_EMAIL=admin@company.com


# ============================================================================
# RATE LIMITING
# ============================================================================

# Enable rate limiting
RATE_LIMIT_ENABLED=True

# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Requests per hour per IP
RATE_LIMIT_PER_HOUR=1000


# ============================================================================
# INITIAL ADMIN SETUP
# ============================================================================

# Initial admin user credentials
# IMPORTANT: Change these after first login!
INITIAL_ADMIN_EMAIL=ali.el-sayed-ali@scouthorizon.onmicrosoft.com
INITIAL_ADMIN_PASSWORD=Kaido1234
INITIAL_ADMIN_NAME=System Administrator
INITIAL_ADMIN_PHONE=+1-514-967-4308


# ============================================================================
# BUSINESS RULES CONFIGURATION
# ============================================================================

# Default maximum borrow days
DEFAULT_MAX_BORROW_DAYS=7

# Overdue notification threshold (days before due date)
OVERDUE_WARNING_DAYS=2

# Maximum active borrows per user
MAX_ACTIVE_BORROWS_PER_USER=5

# Maximum quantity per transaction
MAX_QUANTITY_PER_TRANSACTION=10

# Require admin approval for high-value items
REQUIRE_APPROVAL_THRESHOLD=1000


# ============================================================================
# PAGINATION DEFAULTS
# ============================================================================

# Default page size for list endpoints
DEFAULT_PAGE_SIZE=50

# Maximum page size
MAX_PAGE_SIZE=100


# ============================================================================
# CACHE CONFIGURATION (Optional - Redis)
# ============================================================================

# Enable caching
CACHE_ENABLED=False

# Redis connection
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL (time to live in seconds)
CACHE_TTL=3600


# ============================================================================
# MONITORING AND LOGGING
# ============================================================================

# Enable request logging
REQUEST_LOGGING=True

# Log file path
LOG_FILE_PATH=./logs/app.log

# Maximum log file size (MB)
LOG_MAX_SIZE=10

# Number of backup log files
LOG_BACKUP_COUNT=5

# Enable performance monitoring
PERFORMANCE_MONITORING=True

# Sentry DSN for error tracking (optional)
SENTRY_DSN=


# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

# Automatic database backup
AUTO_BACKUP_ENABLED=True

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup directory
BACKUP_DIR=./backups


# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
ENABLE_USER_REGISTRATION=False
ENABLE_EMAIL_VERIFICATION=False
ENABLE_TWO_FACTOR_AUTH=False
ENABLE_API_VERSIONING=True
ENABLE_SWAGGER_DOCS=True
ENABLE_METRICS_ENDPOINT=True


# ============================================================================
# COMPANY-SPECIFIC SETTINGS
# ============================================================================

# Company name
COMPANY_NAME=Your Company Name

# Company email domain (for validation)
COMPANY_EMAIL_DOMAIN=company.com

# Company timezone
TIMEZONE=UTC

# Business hours (for notifications)
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00


# ============================================================================
# INTEGRATION SETTINGS (Optional)
# ============================================================================

# Slack webhook for notifications
SLACK_WEBHOOK_URL=

# Microsoft Teams webhook
TEAMS_WEBHOOK_URL=

# Google Analytics tracking ID
GA_TRACKING_ID=

# External API keys (if needed)
EXTERNAL_API_KEY=
EXTERNAL_API_SECRET=


# ============================================================================
# DEVELOPMENT SETTINGS (Development only)
# ============================================================================

# Auto-reload on code changes (development only)
AUTO_RELOAD=True

# Show detailed error messages
SHOW_ERROR_DETAILS=True

# Enable API documentation
ENABLE_DOCS=True

# Database echo SQL queries (for debugging)
DB_ECHO=False

# Seed sample data on startup
SEED_SAMPLE_DATA=False


# ============================================================================
# PRODUCTION SETTINGS (Production only)
# ============================================================================

# Use these settings for production deployment

# HTTPS only
# FORCE_HTTPS=True

# Secure cookies
# SECURE_COOKIES=True

# Session cookie settings
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_HTTPONLY=True
# SESSION_COOKIE_SAMESITE=Lax

# Content Security Policy
# CSP_ENABLED=True

# HSTS (HTTP Strict Transport Security)
# HSTS_ENABLED=True
# HSTS_MAX_AGE=31536000


# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit this file with real credentials to version control
# 2. Use different values for development, staging, and production
# 3. Rotate SECRET_KEY regularly in production
# 4. Use strong passwords for database and admin accounts
# 5. Enable HTTPS in production
# 6. Set DEBUG=False in production
# 7. Review and adjust rate limiting based on your needs
# 8. Configure email settings if you want notifications
# 9. Set up regular database backups
# 10. Monitor logs and set up alerts for production


# ============================================================================
# Api- key
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# OR Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

OLLAMA_NUM_GPU=99

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
